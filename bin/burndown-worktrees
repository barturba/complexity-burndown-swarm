#!/usr/bin/env bash
set -euo pipefail

TOOL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET_ROOT="$(cd "${BURNDOWN_TARGET_REPO:-$PWD}" && pwd)"
BRANCH_PREFIX="${BURNDOWN_BRANCH_PREFIX:-agent}"
WORKTREES_PARENT="${BURNDOWN_WORKTREES_DIR:-$(dirname "$TARGET_ROOT")/$(basename "$TARGET_ROOT")-burndown-worktrees}"
ALLOW_DIRTY_MAIN="${BURNDOWN_ALLOW_DIRTY_MAIN:-0}"

read -r -a AGENTS <<< "${BURNDOWN_AGENTS:-A B C D}"

usage() {
  cat <<'USAGE'
Usage: bin/burndown-worktrees <command> [options]

Commands:
  init [--allow-dirty-main]
      Create or reuse agent worktrees for BURNDOWN_AGENTS.

  status
      Show worktree path, branch, and dirty state for each agent.

  sync [--allow-dirty-main]
      Rebase clean agent branches onto target main. Dirty worktrees are skipped.

  path <agent>
      Print one agent worktree path.
USAGE
}

normalize_agent() {
  local input="${1:-}"
  local agent

  input="${input#agent-}"
  input="${input#agent/}"
  input="$(printf "%s" "$input" | tr '[:lower:]' '[:upper:]')"

  for agent in "${AGENTS[@]}"; do
    if [ "$input" = "$agent" ]; then
      printf "%s\n" "$agent"
      return 0
    fi
  done

  echo "Unknown agent: ${1:-<missing>} (expected: ${AGENTS[*]})" >&2
  exit 64
}

branch_for_agent() {
  printf "%s/%s\n" "$BRANCH_PREFIX" "$1"
}

path_for_agent() {
  printf "%s/agent-%s\n" "$WORKTREES_PARENT" "$1"
}

worktree_dirty() {
  [ -n "$(git -C "$1" status --short 2>/dev/null)" ]
}

require_clean_main() {
  local allow_dirty="${1:-0}"

  if [ "$allow_dirty" = "1" ] || [ "$ALLOW_DIRTY_MAIN" = "1" ]; then
    return 0
  fi

  if worktree_dirty "$TARGET_ROOT"; then
    echo "Refusing to continue because target main is dirty: $TARGET_ROOT" >&2
    git -C "$TARGET_ROOT" status --short >&2
    exit 1
  fi
}

ensure_worktree() {
  local agent="$1"
  local path branch current_branch

  path="$(path_for_agent "$agent")"
  branch="$(branch_for_agent "$agent")"

  if [ -e "$path" ] && ! git -C "$path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Path exists but is not a git worktree: $path" >&2
    exit 1
  fi

  if [ ! -d "$path" ]; then
    mkdir -p "$WORKTREES_PARENT"
    if git -C "$TARGET_ROOT" show-ref --verify --quiet "refs/heads/$branch"; then
      git -C "$TARGET_ROOT" worktree add "$path" "$branch"
    else
      git -C "$TARGET_ROOT" worktree add -b "$branch" "$path" main
    fi
  fi

  current_branch="$(git -C "$path" branch --show-current)"
  if [ "$current_branch" != "$branch" ]; then
    echo "Expected $path to be on $branch, but it is on $current_branch" >&2
    exit 1
  fi

  cat > "$path/.env.burndown" <<ENV
# Generated by complexity-burndown-swarm. Local only.
export BURNDOWN_AGENT=$agent
export BURNDOWN_TARGET_REPO=$(printf "%q" "$TARGET_ROOT")
export BURNDOWN_STATE_DIR=$(printf "%q" "${BURNDOWN_STATE_DIR:-$TARGET_ROOT/.burndown-swarm}")
export BURNDOWN_AGENTS=$(printf "%q" "${BURNDOWN_AGENTS:-A B C D}")
ENV
}

command_init() {
  local allow_dirty=0
  local agent path

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --allow-dirty-main) allow_dirty=1 ;;
      -h|--help) usage; exit 0 ;;
      *) echo "Unknown init option: $1" >&2; exit 64 ;;
    esac
    shift
  done

  require_clean_main "$allow_dirty"

  echo "Target repo: $TARGET_ROOT"
  echo "Worktrees: $WORKTREES_PARENT"
  echo "Agents: ${AGENTS[*]}"

  for agent in "${AGENTS[@]}"; do
    path="$(path_for_agent "$agent")"
    echo
    echo "== agent-$agent =="
    ensure_worktree "$agent"
    echo "  path: $path"
  done
}

command_status() {
  local agent path branch dirty

  echo "Target repo: $TARGET_ROOT"
  echo "Worktrees: $WORKTREES_PARENT"
  for agent in "${AGENTS[@]}"; do
    path="$(path_for_agent "$agent")"
    branch="$(branch_for_agent "$agent")"
    if [ ! -d "$path" ]; then
      echo "agent-$agent missing $path"
      continue
    fi
    if worktree_dirty "$path"; then
      dirty=dirty
    else
      dirty=clean
    fi
    printf "agent-%s\t%s\t%s\t%s\n" "$agent" "$branch" "$dirty" "$path"
  done
}

command_sync() {
  local allow_dirty=0
  local agent path branch

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --allow-dirty-main) allow_dirty=1 ;;
      -h|--help) usage; exit 0 ;;
      *) echo "Unknown sync option: $1" >&2; exit 64 ;;
    esac
    shift
  done

  require_clean_main "$allow_dirty"
  for agent in "${AGENTS[@]}"; do
    path="$(path_for_agent "$agent")"
    branch="$(branch_for_agent "$agent")"
    if [ ! -d "$path" ]; then
      echo "skip agent-$agent: missing"
      continue
    fi
    if worktree_dirty "$path"; then
      echo "skip agent-$agent: dirty"
      continue
    fi
    git -C "$path" fetch --all --quiet || true
    git -C "$path" rebase main
    echo "synced $branch"
  done
}

command="${1:-}"
shift || true

case "$command" in
  init) command_init "$@" ;;
  status) command_status ;;
  sync) command_sync "$@" ;;
  path)
    [ "$#" -eq 1 ] || { echo "Usage: bin/burndown-worktrees path <agent>" >&2; exit 64; }
    path_for_agent "$(normalize_agent "$1")"
    ;;
  -h|--help|"") usage ;;
  *) echo "Unknown command: $command" >&2; usage >&2; exit 64 ;;
esac
